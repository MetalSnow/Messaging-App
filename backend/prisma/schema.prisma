// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
enum Status {
  PENDING 
  ACCEPTED
}

model User {
  id               Int        @id @default(autoincrement())
  name             String?     @db.VarChar(100)
  username         String     @unique @db.VarChar(50)
  email            String     @unique @db.VarChar(255)
  password         String     @db.VarChar(255)
  profiles         Profile?
  friends1         Friends[]  @relation("UserFriends1")
  friends2         Friends[]  @relation("UserFriends2")
  sentMessages     Messages[] @relation("sentMessages")
  receivedMessages Messages[] @relation("receivedMessages")
}

model Profile {
  id         Int     @id @default(autoincrement())
  bio        String? @db.VarChar(255)
  gender     Gender?
  profilePic String? @db.VarChar(255)
  coverPic   String? @db.VarChar(255)
  userId     Int     @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friends {
  userId1 Int
  userId2 Int
  status  Status @default(PENDING)

  user1 User @relation("UserFriends1", fields: [userId1], references: [id], onDelete: Cascade)
  user2 User @relation("UserFriends2", fields: [userId2], references: [id], onDelete: Cascade)

  @@id([userId1, userId2])
}

model Messages {
  id         Int      @id @default(autoincrement())
  message    String
  senderId   Int
  receiverId Int
  createdAt  DateTime @default(now())

  user1 User @relation("sentMessages", fields: [senderId], references: [id])
  user2 User @relation("receivedMessages", fields: [receiverId], references: [id])
}
